{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base", "schedule:weekly"],
  "packageRules": [
    {
      "description": "Group non-breaking updates",
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "matchJsonata": ["isBreaking != true"],
      "groupName": "Non-breaking updates"
    },
    {
      // gdbstub 0.8+ contains breaking API changes; stay on 0.7 for now
      "description": "Ignore gdbstub updates while it's still 0.7",
      "matchPackageNames": ["gdbstub"],
      "allowedVersions": "<0.8.0"
    }
  ],
  // Don't try to update files generated by cargo dist
  "ignorePaths": [".github/workflows/v-release.yml"],
  "labels": ["changelog:skip", "dependencies"],
}
